{
  "session": {
    "dimensions": [
      "chat"
    ]
  },
  "version": 3,
  "isolation": {},
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "allow_read_outside_workspace": false,
      "provider": "",
      "model_name": "gemma-a4b",
      "model_fallbacks": ["gemma-31b"],
      "max_tokens": 8192,
      "context_window": 65536,
      "temperature": 0.5,
      "max_tool_iterations": 30,
      "summarize_message_threshold": 20,
      "summarize_token_percent": 75,
      "routing": {
        "enabled": true,
        "light_model": "gemini-lite",
        "threshold": 0.15
      },
      "steering_mode": "one-at-a-time",
      "subturn": {
        "max_depth": 2,
        "max_concurrent": 1,
        "default_timeout_minutes": 3,
        "default_token_budget": 4096,
        "concurrency_timeout_sec": 0
      },
      "tool_feedback": {
        "enabled": false,
        "max_args_length": 300,
        "separate_messages": false
      },
      "split_on_marker": false,
      "max_llm_retries": 3,
      "llm_retry_backoff_secs": 5
    }
  },
  "evolution": {
    "enabled": true,
    "mode": "observe",
    "min_task_count": 2,
    "min_success_ratio": 0.7,
    "cold_path_trigger": "after_turn"
  },
  "channel_list": {
    "telegram": {
      "enabled": false,
      "type": "telegram",
      "allow_from": [
        ""
      ],
      "reasoning_channel_id": "",
      "group_trigger": {},
      "typing": {
        "enabled": true
      },
      "placeholder": {
        "enabled": true,
        "text": [
          "Thinking... ðŸ’­"
        ]
      },
      "settings": {
        "base_url": "",
        "proxy": "",
        "streaming": {
          "enabled": true,
          "throttle_seconds": 3,
          "min_growth_chars": 300
        },
        "use_markdown_v2": true,
        "media_group_delay_ms": 800
      }
    }
  },
  "model_list": [
    {
      "model_name": "gemini-audio",
      "provider": "gemini",
      "model": "gemini/gemini-live-2.5-flash-native-audio",
      "api_base": "https://generativelanguage.googleapis.com/v1beta"
    },
    {
      "model_name": "gemini-lite",
      "provider": "gemini",
      "model": "gemini/gemini-3.1-flash-lite",
      "api_base": "https://generativelanguage.googleapis.com/v1beta",
      "fallbacks": [
        "gemini-lite__key_1"
      ],
      "rpm": 14
    },
    {
      "model_name": "gemma-a4b",
      "provider": "gemini",
      "model": "gemini/gemma-4-26b-a4b-it",
      "api_base": "https://generativelanguage.googleapis.com/v1beta",
      "fallbacks": [
        "gemma-a4b__key_1"
      ],
      "rpm": 14
    },
    {
      "model_name": "gemma-31b",
      "provider": "gemini",
      "model": "gemini/gemma-4-31b-it",
      "api_base": "https://generativelanguage.googleapis.com/v1beta",
      "fallbacks": [
        "gemma-31b__key_1"
      ],
      "rpm": 14
    },
    {
      "model_name": "groq",
      "provider": "groq",
      "model": "groq/llama-3.3-70b-versatile",
      "api_base": "https://api.groq.com/openai/v1",
      "rpm": 29,
      "max_tokens_field": "max_tokens"
    },
    {
      "model_name": "openrouter",
      "provider": "openrouter",
      "model": "nvidia/nemotron-3-super-120b-a12b:free",
      "api_base": "https://openrouter.ai/api/v1",
      "rpm": 19
    },
    {
      "model_name": "nvidia",
      "provider": "nvidia",
      "model": "nvidia/nemotron-3-super-120b-a12b",
      "api_base": "https://integrate.api.nvidia.com/v1",
      "rpm": 39
    }
  ],
  "gateway": {
    "host": "localhost",
    "port": 18790,
    "hot_reload": false,
    "log_level": "error"
  },
  "events": {
    "logging": {
      "enabled": true,
      "include": [
        "agent.*"
      ],
      "min_severity": "info"
    }
  },
  "hooks": {
    "enabled": true,
    "defaults": {
      "observer_timeout_ms": 500,
      "interceptor_timeout_ms": 5000,
      "approval_timeout_ms": 60000
    }
  },
  "tools": {
    "allow_read_paths": null,
    "allow_write_paths": null,
    "filter_sensitive_data": true,
    "filter_min_length": 8,
    "web": {
      "enabled": true,
      "brave": {
        "enabled": false,
        "max_results": 5
      },
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      },
      "gemini": {
        "enabled": false,
        "model": "gemini-2.5-flash",
        "max_results": 5
      },
      "perplexity": {
        "enabled": false,
        "max_results": 5
      },
      "glm_search": {
        "enabled": false,
        "base_url": "https://open.bigmodel.cn/api/paas/v4/web_search",
        "search_engine": "search_std",
        "max_results": 5
      },
      "provider": "auto",
      "prefer_native": true,
      "fetch_limit_bytes": 524288,
      "format": "plaintext"
    },
    "cron": {
      "enabled": true,
      "exec_timeout_minutes": 5,
      "allow_command": true
    },
    "exec": {
      "enabled": true,
      "enable_deny_patterns": true,
      "allow_remote": true,
      "custom_deny_patterns": [
        "rm -rf",
        "rm -r",
        "dd of=",
        "dd if=",
        "shred",
        "wipefs",
        "mkfs",
        "fdisk",
        "parted",
        "sfdisk",
        "sgdisk",
        "blkdiscard",
        "shutdown",
        "reboot",
        "poweroff",
        "chmod 0777",
        "chown root:root",
        "curl | sh",
        "wget | sh",
        "nohup rm",
        "/dev/sd",
        "/dev/nvme"
      ],
      "custom_allow_patterns": [
        "ls",
        "pwd",
        "cat",
        "git ",
        "python3",
        "python",
        "node",
        "ssh",
        "scp",
        "curl",
        "wget",
        "systemctl",
        "journalctl"
      ],
      "timeout_seconds": 60
    },
    "skills": {
      "enabled": true,
      "registries": {
        "clawhub": {
          "base_url": "https://clawhub.ai",
          "enabled": true
        },
        "github": {
          "base_url": "https://github.com",
          "enabled": true
        }
      },
      "github": {},
      "max_concurrent_searches": 2,
      "search_cache": {
        "max_size": 50,
        "ttl_seconds": 300
      }
    },
    "media_cleanup": {
      "enabled": true,
      "max_age_minutes": 30,
      "interval_minutes": 5
    },
    "mcp": {
      "enabled": false,
      "discovery": {
        "enabled": false,
        "ttl": 5,
        "max_search_results": 5,
        "use_bm25": true,
        "use_regex": false
      },
      "max_inline_text_chars": 16384
    },
    "append_file": {
      "enabled": true
    },
    "edit_file": {
      "enabled": true
    },
    "find_skills": {
      "enabled": true
    },
    "i2c": {
      "enabled": false
    },
    "install_skill": {
      "enabled": true
    },
    "list_dir": {
      "enabled": true
    },
    "load_image": {
      "enabled": true
    },
    "message": {
      "enabled": true
    },
    "read_file": {
      "enabled": true,
      "mode": "bytes",
      "max_read_file_size": 65536
    },
    "serial": {
      "enabled": false
    },
    "send_file": {
      "enabled": true
    },
    "send_tts": {
      "enabled": false
    },
    "spawn": {
      "enabled": true
    },
    "spawn_status": {
      "enabled": false
    },
    "spi": {
      "enabled": false
    },
    "subagent": {
      "enabled": true
    },
    "web_fetch": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "devices": {
    "enabled": false,
    "monitor_usb": false
  },
  "voice": {
    "model_name": "gemini-audio",
    "echo_transcription": true
  }
}
